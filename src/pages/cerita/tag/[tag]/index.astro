---
import { mops } from "@/lib/data";
import { filterMopsByDate } from "@/lib/utils";
import Layout from "@/layouts/Layout.astro";
import { ArrowLeft } from "lucide-react";
import Link from "@/components/Link.astro";
import { Button } from "@/components/ui/button";

const { tag } = Astro.params;

if (!tag) {
  return Astro.redirect("/cerita/");
}

const availableMops = filterMopsByDate(mops);
const tagMops = availableMops.filter((m) => m.tags?.includes(tag));

if (tagMops.length === 0) {
  return Astro.redirect("/404/");
}

const tagTitle = tag.charAt(0).toUpperCase() + tag.slice(1);
---

<Layout
  title={`Cerita MOP Kategori ${tagTitle}`}
  description={`Kumpulan cerita Mop dengan kategori ${tag}. Temukan kisah lucu dan menarik tentang ${tag}.`}
>
  <main class="mx-auto max-w-2xl px-4 py-12">
    <div class="mb-8">
      <Button variant="ghost" size="sm" className="mb-4 -ml-2">
        <Link href="/cerita/" class="flex items-center gap-2 text-muted-foreground hover:text-blue-600 transition-colors">
          <ArrowLeft className="h-4 w-4" />
          Semua Cerita
        </Link>
      </Button>
      <h1 class="text-3xl font-bold">Kategori: {tagTitle}</h1>
      <p class="text-muted-foreground mt-2">
        Menampilkan {tagMops.length} cerita dalam kategori ini.
      </p>
    </div>

    <div class="space-y-6">
      {
        tagMops.map((mop) => (
          <div class="border-b border-gray-100 dark:border-gray-800 pb-6 last:border-0">
            <a href={`/cerita/${mop.id}/`} class="group block">
              <div class="mb-2 flex flex-wrap gap-2">
                {mop.tags?.map((t) => (
                  <span
                    class:list={[
                      "rounded-full px-2 py-0.5 text-xs font-medium",
                      t === tag 
                        ? "bg-blue-600 text-white" 
                        : "bg-blue-50 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400"
                    ]}
                  >
                    {t}
                  </span>
                ))}
              </div>
              <h3 class="text-xl font-semibold mb-2 group-hover:text-blue-600 transition-colors">
                {mop.title}
              </h3>
              <p class="text-sm text-muted-foreground mb-3">{mop.date}</p>
              <p class="text-gray-600 dark:text-gray-400 line-clamp-2">
                {mop.content[0]?.content}
              </p>
            </a>
          </div>
        ))
      }
    </div>

    <div class="mt-12 flex justify-center">
      <Button variant="outline">
        <Link href="/cerita/" class="flex items-center gap-2">
          Lihat Kategori Lain
        </Link>
      </Button>
    </div>
  </main>
</Layout>
