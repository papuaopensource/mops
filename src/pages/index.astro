---
import Layout from "@/layouts/Layout.astro";
import Link from "@/components/Link.astro";

import { mops } from "@/lib/data";
import { getTodayMop } from "@/lib/utils";

const todayMop = getTodayMop(mops);
---

<Layout
  title="Cerita Mop Papua Hari Ini"
  description="Baca cerita MOP Papua hari ini. Temukan kisah lucu dan menghibur yang ditulis dalam dialek lokal Papua."
>
  {
    !todayMop ? (
      <main class="mx-auto max-w-2xl px-4 py-16 text-center">
        <h1 class="mb-4 text-2xl font-semibold text-neutral-100">Belum Ada Cerita</h1>
        <p class="mb-8 text-neutral-400">
          Belum ada cerita yang tersedia untuk hari ini. Silakan kembali lagi
          nanti.
        </p>
        <a
          href="/cerita/"
          class="inline-flex items-center justify-center rounded border border-neutral-700 px-4 py-2 text-sm text-neutral-300 transition-colors hover:border-neutral-500 hover:text-neutral-100"
        >
          Lihat Semua Cerita
        </a>
      </main>
    ) : (
      <main class="mx-auto max-w-2xl px-4 py-16">
        <div class="mb-10 text-center">
          <p class="mb-3 text-xs uppercase tracking-widest text-neutral-500">hari ini</p>
          <h1 class="mb-2 text-2xl font-semibold text-neutral-100">{todayMop.title}</h1>
          <p class="mb-3 text-sm text-neutral-500">{todayMop.date}</p>
          {todayMop.tags && todayMop.tags.length > 0 && (
            <div class="flex flex-wrap justify-center gap-1.5">
              {todayMop.tags.map((tag: string) => (
                <a
                  href={`/cerita/tag/${tag}/`}
                  class="rounded border border-neutral-700 px-2 py-0.5 text-xs text-neutral-500 transition-colors hover:border-neutral-500 hover:text-neutral-300"
                >
                  {tag}
                </a>
              ))}
            </div>
          )}
        </div>

        <div class="space-y-5">
          {todayMop.content.map((part: any) => (
            <div class="flex flex-col space-y-1">
              {part.type === "narration" ? (
                <p class="border-l border-neutral-700 pl-4 text-sm text-neutral-400 leading-relaxed">
                  {part.content}
                </p>
              ) : (
                <>
                  <div class="text-xs font-medium uppercase tracking-wide text-neutral-500">{part.speaker}</div>
                  <div class="rounded border border-neutral-800 bg-neutral-800/50 px-4 py-3 text-sm text-neutral-200 leading-relaxed">
                    {part.content}
                  </div>
                </>
              )}
            </div>
          ))}
        </div>

        <div class="mt-12 flex items-center justify-end">
          <Link
            href="/cerita/"
            class="inline-flex items-center gap-2 text-sm text-neutral-400 transition-colors hover:text-neutral-100"
          >
            Baca yang Lain
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </Link>
        </div>
      </main>
    )
  }
</Layout>
