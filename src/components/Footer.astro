---
import Link from "@/components/Link.astro";
---

<footer class="mt-auto border-t border-white/10 py-6">
  <div
    class="mx-auto flex max-w-4xl flex-col space-y-3 px-4 text-sm text-neutral-500 md:flex-row md:items-center md:justify-between md:space-y-0"
  >
    <div>
      © 2026
      <Link
        href="https://papuaopensource.github.io"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-neutral-200 transition-colors"
      >
        Papua Open Source
      </Link>
    </div>
    <div class="flex items-center space-x-3">
      <Link
        href="https://app.formbricks.com/s/clzwui3i00000igj00vcvgg0n"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-neutral-200 transition-colors"
      >
        feedback
      </Link>
      <span class="text-neutral-600">&bull;</span>
      <Link
        href="https://mops.betteruptime.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-neutral-200 transition-colors"
      >
        status
      </Link>
      <span class="text-neutral-600">&bull;</span>
      <Link
        href="https://github.com/papuaopensource/mops/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-neutral-200 transition-colors"
      >
        github
      </Link>
    </div>
  </div>
</footer>
